{
  "name": "@liqo/sdk",
  "version": "2.0.0",
  "description": "Official TypeScript & JavaScript SDK for Liqo — Global Payments Infrastructure for Modern Businesses. Accept payments in any currency and settle in the asset you want through a single API.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc && npm run build:types",
    "build:types": "dts-bundle-generator --config dts-bundle-generator.config.js",
    "dev": "tsc --watch",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "liqo",
    "payments",
    "payments-api",
    "payment-infrastructure",
    "fintech",
    "checkout",
    "stellar",
    "stablecoins",
    "sdk",
    "typescript"
  ],
  "license": "MIT",
  "homepage": "https://github.com/liqoprotocol/liqo-sdk#readme",
  "bugs": {
    "url": "https://github.com/liqoprotocol/liqo-sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/liqoprotocol/liqo-sdk"
  },
  "dependencies": {
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "dts-bundle-generator": "^9.5.1",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  }
}
